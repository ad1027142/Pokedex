<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Pokedex.MainPage"
             Title="Pokedex">
  <Grid RowDefinitions="Auto,*" Padding="12">
    <!-- Image row -->
    <Grid Row="0" HorizontalOptions="Center">
      <Image x:Name="PokemonImage"
             Aspect="AspectFit"
             WidthRequest="220"
             HeightRequest="250"/>
    </Grid>

    <!-- Info row -->
    <ScrollView Grid.Row="1">
      <Frame x:Name="InfoFrame"
             Margin="0,12,0,0"
             Padding="20"
             CornerRadius="12"
             HasShadow="True"
             BackgroundColor="#FFFFFF">
        <VerticalStackLayout Spacing="6">
          <Label x:Name="NameLabel"
                 Text="Bulbasaur"
                 FontAttributes="Bold"
                 FontSize="22"/>
          <Label x:Name="TypesLabel"
                 Text="Grass, Poison"
                 FontSize="16"/>
          <!-- other info labels -->
        </VerticalStackLayout>
      </Frame>
    </ScrollView>
  </Grid>
</ContentPage>  