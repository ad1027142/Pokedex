<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Pokedex.MainPage">

    <Grid RowDefinitions="*,Auto"
        ColumnDefinitions="*,40*,*"
        BackgroundColor="#cc0000"
        Padding="12">

        <!-- Top row: Main content area with circle button (left), screen (center 40%), and D-pad (right) -->
        <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
          HorizontalOptions="Fill" 
          VerticalOptions="Fill"
          ColumnDefinitions="*,40*,*">
            <!-- Center: Main Content (40% of screen) -->
            <Grid Grid.Column="1" 
            HorizontalOptions="Fill" 
            VerticalOptions="Fill"
            RowDefinitions="Auto,*"
            ColumnDefinitions="*"
            Padding="10">

                <!-- Top: Ellipses -->
                <Grid Grid.Row="0"
              HorizontalOptions="Start"
              VerticalOptions="Start"
              ColumnDefinitions="Auto,Auto,Auto,Auto"
              RowDefinitions="Auto"
              ColumnSpacing="10"
              Padding="10">

                    <!-- Big Ellipse -->
                    <Button Grid.Column="0"
                   BackgroundColor="CornflowerBlue"
                   BorderColor="white"
                   x:Name="vtoggle"
                   BorderWidth="2"
                   Clicked="Volume"
                   CornerRadius="40"
                   WidthRequest="80"
                   HeightRequest="80" />

                    <!-- Small Ellipse 1 -->
                    <Ellipse Grid.Column="1"
                   Fill="OrangeRed"
                   Stroke="Black"
                   StrokeThickness="2"
                   WidthRequest="15"
                   HeightRequest="15"
                   VerticalOptions="Start" />

                    <!-- Small Ellipse 2 -->
                    <Ellipse Grid.Column="2"
                   Fill="Yellow"
                   Stroke="Black"
                   StrokeThickness="2"
                   WidthRequest="15"
                   HeightRequest="15"
                   VerticalOptions="Start" />

                    <!-- Small Ellipse 3 -->
                    <Ellipse Grid.Column="3"
                   Fill="ForestGreen"
                   Stroke="Black"
                   StrokeThickness="2"
                   WidthRequest="15"
                   HeightRequest="15"
                   VerticalOptions="Start" />
                </Grid>

                <!-- Rectangle and Content with Labels -->
                <Grid Grid.Row="1" HorizontalOptions="Fill" VerticalOptions="Fill">
                    <Border StrokeShape="RoundRectangle 5" Stroke="#cc0000" Background="LightGray">
                        <Grid RowDefinitions="*,Auto,Auto,Auto,Auto" ColumnDefinitions="*,*,*">
                            
                            <!-- Image at the top (bound to ViewModel ImageUrl) -->
                            <Image Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                                   x:Name="PokemonImage"
                                   Source="{Binding ImageUrl}"
                                   Aspect="AspectFit"
                                   Margin="10"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   MinimumHeightRequest="140"
                                   MinimumWidthRequest="140" />

                            <!-- Row 1: Headers for data -->
                            <Label Grid.Row="1" Grid.Column="0"
                                   Text="Name"
                                   FontSize="Small"
                                   FontAttributes="Bold"
                                   Padding="5,5,5,0"
                                   TextColor="Black"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   VerticalTextAlignment="Center" />
                            <Label Grid.Row="1" Grid.Column="1"
                                   Text="Type"
                                   FontSize="Small"
                                   FontAttributes="Bold"
                                   Padding="5,5,5,0"
                                   TextColor="Black"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   VerticalTextAlignment="Center"/>
                            <Label Grid.Row="1" Grid.Column="2"
                                   Text="ID"
                                   FontSize="Small"
                                   FontAttributes="Bold"
                                   Padding="5,5,5,0"
                                   TextColor="Black"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   VerticalTextAlignment="Center" />

                            <!-- Row 2: Data labels with borders -->
                            <Border Stroke="Blue" Grid.Row="2" Grid.Column="0" Padding="5" VerticalOptions="Center">
                                <Label
                                   Text="{Binding Name}"
                                   FontSize="Medium"
                                   Padding="5"
                                   TextColor="Black"
                                   MinimumHeightRequest="70"
                                   VerticalTextAlignment="Center"
                                   HorizontalTextAlignment="Center"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Center"/>
                            </Border>
                            <Border Stroke="Red" Grid.Row="2" Grid.Column="1">
                                <Label 
                                   Text="{Binding Types}"
                                   FontSize="Medium"
                                   Padding="5"
                                   TextColor="Black"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                            </Border>
                            <Border Stroke="Green" Grid.Row="2" Grid.Column="2">
                                <Label 
                                   Text="{Binding Id}"
                                   FontSize="Medium"
                                   Padding="5"
                                   TextColor="Black"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                            </Border>

                            <!-- Row 3: Headers for bottom row -->
                            <Label Grid.Row="3" Grid.Column="1"
                                   Text="Height"
                                   FontSize="Small"
                                   FontAttributes="Bold"
                                   Padding="5,5,5,0"
                                   TextColor="Black"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   VerticalTextAlignment="Center" />
                            <Label Grid.Row="3" Grid.Column="2"
                                   Text="Weight"
                                   FontSize="Small"
                                   FontAttributes="Bold"
                                   Padding="5,5,5,0"
                                   TextColor="Black"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Start" />

                            <!-- Row 4: Bottom row with Polygon and 2 labels -->
                            <Polygon Grid.Row="4" Grid.Column="0"
                                     Points="0,100 0,0 100,100"
                                     Stroke="#cc0000"
                                     Fill="#cc0000"
                                     StrokeThickness="2"
                                     HorizontalOptions="Start"
                                     VerticalOptions="End"
                                     WidthRequest="100"
                                     HeightRequest="100" />
                            <Border Stroke="Yellow" Grid.Row="4" Grid.Column="1" VerticalOptions="Center">
                                <Label 
                                   Text="{Binding Height}"
                                   FontSize="Medium"
                                   Padding="5"
                                   MinimumHeightRequest="90"
                                   TextColor="Black"
                                   HorizontalOptions="Center"
                                   VerticalTextAlignment="Center"
                                   VerticalOptions="Center" />
                            </Border>
                            <Border Stroke="Black" Grid.Row="4" Grid.Column="2">
                                <Label 
                                   Text="{Binding Weight}"
                                   FontSize="Medium"
                                   Padding="5"
                                   TextColor="Black"
                                    VerticalTextAlignment="Center"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                            </Border>

                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- Right side: Empty for balance -->
            <StackLayout Grid.Column="2" 
                   HorizontalOptions="Center" 
                   VerticalOptions="Center"
                   Padding="10" />
        </Grid>

        <!-- Bottom row: Submit button (left), Entry (center), and D-Pad (right) -->
        <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
          ColumnDefinitions="Auto,*,Auto"
          HorizontalOptions="Fill"
          VerticalOptions="Center"
          Padding="10">

            <!-- Submit Button (Left) -->
            <Button Grid.Column="0"
              x:Name="Submit"
              HeightRequest="80"
              WidthRequest="80"
              CornerRadius="40"
              BackgroundColor="#555555"
              Clicked="OnSubmitClicked"
                    />

            <!-- Entry (Center) -->
            <Entry Grid.Column="1"
             x:Name="InputEntry"
             Placeholder="Type ID/Name"
             HorizontalTextAlignment="Center"
             Completed="OnSubmitClicked"
             HorizontalOptions="Fill"
             VerticalOptions="Center"
             TextColor="White"
             PlaceholderColor="White"/>

            <!-- D-Pad (Right) -->
            <Grid Grid.Column="2"
            RowDefinitions="Auto,Auto,Auto"
            ColumnDefinitions="Auto,Auto,Auto">

                <!-- Up -->
                <Button Grid.Row="0" Grid.Column="1"
                HeightRequest="40"
                WidthRequest="40"
                CornerRadius="3"
                BackgroundColor="#555555"
                Text="↑" 
                FontSize="Small"
                x:Name="up"/>

                <!-- Left -->
                <Button Grid.Row="1" Grid.Column="0"
                HeightRequest="40"
                WidthRequest="40"
                CornerRadius="3"
                BackgroundColor="#555555"
                Text="←"
                Clicked="Left"
                FontSize="Small"
                x:Name="left"/>

                <!-- Center -->
                <Button Grid.Row="1" Grid.Column="1"
                HeightRequest="40"
                WidthRequest="40"
                CornerRadius="3"
                BackgroundColor="#555555"
                Text="●"
                FontSize="Medium"
                x:Name="cener"/>

                <!-- Right -->
                <Button Grid.Row="1" Grid.Column="2"
                HeightRequest="40"
                WidthRequest="40"
                CornerRadius="3"
                BackgroundColor="#555555"
                Text="→" 
                Clicked="Right"
                FontSize="Small"
                x:Name="rightg"/>

                <!-- Down -->
                <Button Grid.Row="2" Grid.Column="1"
                HeightRequest="40"
                WidthRequest="40"
                CornerRadius="3"
                BackgroundColor="#555555"
                Text="↓" 
                FontSize="Small"
                x:Name="bottm"/>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
