<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Pokedex.MainPage">

    <Grid RowDefinitions="*,Auto"
        ColumnDefinitions="*,40*,*"
        BackgroundColor="#cc0000"
        Padding="12">

        <!-- Top row: Main content area with circle button (left), screen (center 40%), and D-pad (right) -->
        <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
          HorizontalOptions="Fill" 
          VerticalOptions="Fill"
          ColumnDefinitions="*,40*,*">
            <!-- Center: Main Content (40% of screen) -->
            <Grid Grid.Column="1" 
            HorizontalOptions="Fill" 
            VerticalOptions="Fill"
            RowDefinitions="Auto,*"
            ColumnDefinitions="*"
            Padding="10">

                <!-- Top: Ellipses -->
                <Grid Grid.Row="0"
              HorizontalOptions="Start"
              VerticalOptions="Start"
              ColumnDefinitions="Auto,Auto,Auto,Auto"
              RowDefinitions="Auto"
              ColumnSpacing="10"
              Padding="10">

                    <!-- Big Ellipse -->
                    <Ellipse Grid.Column="0"
                   Fill="CornflowerBlue"
                   Stroke="white"
                   StrokeThickness="5"
                   WidthRequest="80"
                   HeightRequest="80" />

                    <!-- Small Ellipse 1 -->
                    <Ellipse Grid.Column="1"
                   Fill="OrangeRed"
                   Stroke="Black"
                   StrokeThickness="2"
                   WidthRequest="15"
                   HeightRequest="15"
                   VerticalOptions="Start" />

                    <!-- Small Ellipse 2 -->
                    <Ellipse Grid.Column="2"
                   Fill="Yellow"
                   Stroke="Black"
                   StrokeThickness="2"
                   WidthRequest="15"
                   HeightRequest="15"
                   VerticalOptions="Start" />

                    <!-- Small Ellipse 3 -->
                    <Ellipse Grid.Column="3"
                   Fill="ForestGreen"
                   Stroke="Black"
                   StrokeThickness="2"
                   WidthRequest="15"
                   HeightRequest="15"
                   VerticalOptions="Start" />
                </Grid>

                <!-- Rectangle and Content with Labels -->
                <Grid Grid.Row="1" HorizontalOptions="Fill" VerticalOptions="Fill">
                    <Border StrokeShape="RoundRectangle 5" Stroke="#cc0000" Background="LightGray">
                        <Grid RowDefinitions="*,Auto,Auto" ColumnDefinitions="*,*,*">
                            
                            <!-- Image at the top -->
                            <Image Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                                   x:Name="PokemonImage"
                                   Aspect="AspectFit"
                                   Margin="10"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Fill" />

                            <!-- Row with 3 labels above the polygon -->
                            <Label Grid.Row="1" Grid.Column="0"
                                   x:Name="Name"
                                   Text="Name"
                                   FontSize="Medium"
                                   Padding="5"
                                   TextColor="Black"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                            
                            <Label Grid.Row="1" Grid.Column="1"
                                   x:Name="Type"
                                   Text="Type"
                                   FontSize="Medium"
                                   Padding="5"
                                   TextColor="Black"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                            
                            <Label Grid.Row="1" Grid.Column="2"
                                   x:Name="ID"
                                   Text="ID"
                                   FontSize="Medium"
                                   Padding="5"
                                   TextColor="Black"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />

                            <!-- Bottom row: Polygon (left) and 2 labels (right) -->
                            <Polygon Grid.Row="2" Grid.Column="0"
                                     Points="0,100 0,0 100,100"
                                     Stroke="#cc0000"
                                     Fill="#cc0000"
                                     StrokeThickness="2"
                                     HorizontalOptions="Start"
                                     VerticalOptions="End"
                                     WidthRequest="100"
                                     HeightRequest="100" />

                            <Label Grid.Row="2" Grid.Column="1"
                                   x:Name="Height"
                                   Text="Height"
                                   FontSize="Medium"
                                   Padding="5"
                                   TextColor="Black"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                            
                            <Label Grid.Row="2" Grid.Column="2"
                                   x:Name="Weight"
                                   Text="Weight"
                                   FontSize="Medium"
                                   Padding="5"
                                   TextColor="Black"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />

                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- Right side: Empty for balance -->
            <StackLayout Grid.Column="2" 
                   HorizontalOptions="Center" 
                   VerticalOptions="Center"
                   Padding="10" />
        </Grid>

        <!-- Bottom row: Submit button (left), Entry (center), and D-Pad (right) -->
        <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
          ColumnDefinitions="Auto,*,Auto"
          HorizontalOptions="Fill"
          VerticalOptions="Center"
          Padding="10">

            <!-- Submit Button (Left) -->
            <Button Grid.Column="0"
              x:Name="Submit"
              HeightRequest="80"
              WidthRequest="80"
              CornerRadius="40"
              BackgroundColor="#555555"
              Clicked="OnSubmitClicked"
                    />

            <!-- Entry (Center) -->
            <Entry Grid.Column="1"
             x:Name="InputEntry"
             Placeholder="Type ID/Name and press Enter"
             Completed="OnSubmitClicked"
             HorizontalOptions="Fill"
             VerticalOptions="Center"
             TextColor="White"
             PlaceholderColor="White"/>

            <!-- D-Pad (Right) -->
            <Grid Grid.Column="2"
            RowDefinitions="Auto,Auto,Auto"
            ColumnDefinitions="Auto,Auto,Auto">

                <!-- Up -->
                <Button Grid.Row="0" Grid.Column="1"
                HeightRequest="40"
                WidthRequest="40"
                CornerRadius="3"
                BackgroundColor="#555555"
                Text="↑" 
                FontSize="Small"
                x:Name="up"/>

                <!-- Left -->
                <Button Grid.Row="1" Grid.Column="0"
                HeightRequest="40"
                WidthRequest="40"
                CornerRadius="3"
                BackgroundColor="#555555"
                Text="←"
                FontSize="Small"
                x:Name="left"/>

                <!-- Center -->
                <Button Grid.Row="1" Grid.Column="1"
                HeightRequest="40"
                WidthRequest="40"
                CornerRadius="3"
                BackgroundColor="#555555"
                Text="●"
                FontSize="Medium"
                x:Name="cener"/>

                <!-- Right -->
                <Button Grid.Row="1" Grid.Column="2"
                HeightRequest="40"
                WidthRequest="40"
                CornerRadius="3"
                BackgroundColor="#555555"
                Text="→" 
                FontSize="Small"
                x:Name="rightg"/>

                <!-- Down -->
                <Button Grid.Row="2" Grid.Column="1"
                HeightRequest="40"
                WidthRequest="40"
                CornerRadius="3"
                BackgroundColor="#555555"
                Text="↓" 
                FontSize="Small"
                x:Name="bottm"/>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
