<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Pokedex.MainPage">

  <!-- Three rows: main content (fills), rectangle (auto height), entry (auto height) -->
  <Grid RowDefinitions="*,Auto,Auto"
        ColumnDefinitions="*"
        Padding="12"
        HorizontalOptions="Fill" VerticalOptions="Fill">

    <!-- Main content area -->

        <Path Fill="Blue" Stroke="Black" StrokeThickness="2"
      Data="M 0,0 L 200,0 L 200,100 L 20,100 L 0,80 Z"></Path>



            <!-- Bottom text input (valid Grid.Row index 2) -->
    <Entry Grid.Row="2"
           x:Name="InputEntry"
           Placeholder="Type ID/Name and press Enter"
           Completed="OnEntryCompleted"
           HorizontalOptions="Fill"
           Margin="0,10,0,0" />
  </Grid>
</ContentPage>
